# ==========================================
# CodeSync Environment Variables Template
# ==========================================
# Copy this file to .env and fill in your values

# ==========================================
# DATABASE CONFIGURATION
# ==========================================
# MongoDB connection string for production
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/codesync

# ==========================================
# AUTHENTICATION
# ==========================================
# JWT secret key (minimum 32 characters, use strong random string)
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters-long
JWT_REFRESH_SECRET=your-refresh-token-secret-minimum-32-characters-long

# ==========================================
# SERVER CONFIGURATION
# ==========================================
# Server port
PORT=5000

# Environment: development, staging, production
NODE_ENV=production

# ==========================================
# EMAIL CONFIGURATION
# ==========================================
# Gmail configuration (use Gmail App Password, not account password)
EMAIL_USER=codesync@gmail.com
EMAIL_PASSWORD=xxxx-xxxx-xxxx-xxxx
# EMAIL_PASS is also supported for compatibility with the existing server/.env
# EMAIL_PASS=xxxx-xxxx-xxxx-xxxx

# Optional: SendGrid configuration (alternative to Gmail)
# SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxx
# SENDGRID_FROM_EMAIL=noreply@codesync.com

# ==========================================
# AI INTEGRATION
# ==========================================
# Google Generative AI (Gemini) API key
GOOGLE_GENERATIVE_AI_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: OpenAI integration (if adding OpenAI support)
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ==========================================
# FRONTEND CONFIGURATION
# ==========================================
# API URL for frontend (backend endpoint)
REACT_APP_API_URL=https://api.codesync.com

# Socket.IO URL (usually same as API URL, can use WSS for production)
REACT_APP_SOCKET_URL=wss://api.codesync.com

# Frontend environment
REACT_APP_ENV=production

# ==========================================
# OPTIONAL: MONITORING & LOGGING
# ==========================================
# Sentry error tracking (optional but recommended for production)
# SENTRY_DSN=https://xxxxx@xxxxx.ingest.sentry.io/xxxxx

# LogRocket session replay (optional)
# LOGROCKET_APP_ID=xxxxx/xxxxx

# Google Analytics (optional)
# GOOGLE_ANALYTICS_ID=UA-xxxxxxxxx-x

# ==========================================
# OPTIONAL: RATE LIMITING
# ==========================================
# Max requests per window (global rate limit)
RATE_LIMIT_MAX=300

# Rate limit window in milliseconds
RATE_LIMIT_WINDOW_MS=900000  # 15 minutes

# ==========================================
# OPTIONAL: CODE EXECUTION LIMITS
# ==========================================
# Code execution timeout in milliseconds
CODE_EXECUTION_TIMEOUT=10000  # 10 seconds

# Maximum code file size in bytes
MAX_CODE_SIZE=1048576  # 1MB

# ==========================================
# OPTIONAL: FILE UPLOAD LIMITS
# ==========================================
# Max file upload size
MAX_FILE_SIZE=10485760  # 10MB

# Max files per upload
MAX_FILES_PER_UPLOAD=10

# ==========================================
# DOCKER CONFIGURATION
# ==========================================
# Docker registry for execution images
DOCKER_REGISTRY=docker.io

# Docker image for code execution
DOCKER_EXECUTION_IMAGE=codesync/executor:latest

# ==========================================
# DEPLOYMENT
# ==========================================
# Vercel deployment token (for CI/CD)
# VERCEL_TOKEN=xxxxxxxxxxxxxxxxxxxxx

# Render deployment key (for CI/CD)
# RENDER_DEPLOY_HOOK_URL=https://api.render.com/deploy/srv-xxxxx

# ==========================================
# DEVELOPMENT ONLY (Do not use in production)
# ==========================================
# Enable debug logging
DEBUG=false

# Registration email verification is temporarily bypassed in the application.
SKIP_EMAIL_VERIFICATION=true

# Use test database (development only)
# MONGODB_URI=mongodb://localhost:27017/codesync-test

# ==========================================
# NOTES
# ==========================================
# 1. Never commit .env file to version control
# 2. Use strong, random values for JWT secrets
# 3. For Gmail: Use App Passwords (https://myaccount.google.com/apppasswords)
# 4. For production: Use environment-specific values
# 5. Regularly rotate secrets
# 6. Use managed secrets service in production (AWS Secrets Manager, etc.)
